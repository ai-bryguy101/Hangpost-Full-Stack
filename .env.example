# Copy to .env (gitignored) for non-Docker local runs, or set these as
# Codespaces / Vercel / Fly secrets. Never commit real values.

# ---- API ----
ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql+asyncpg://hangpost:hangpost@localhost:5432/hangpost
REDIS_URL=redis://localhost:6379/0

# Ranker version stamped onto every recommendation impression.
MODEL_VERSION=rules-v1

# ---- Optional integrations (unset in local dev) ----
SENTRY_DSN=
CLERK_JWKS_URL=

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:8000
